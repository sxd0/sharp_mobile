<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WaterBalanceController.MainWindow"
        Title="Контроллер водного баланса"
        Width="820"
        Height="640"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Background="#F1F8FB">
  <Grid RowDefinitions="76,*,70">
    <Border Grid.Row="0" Background="#0E7490" Padding="24,14">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="Контроллер водного баланса" Foreground="White" FontSize="24" FontWeight="Bold" />
          <TextBlock Text="F1 - справка" Foreground="#CFFAFE" FontSize="13" />
        </StackPanel>
        <TextBlock x:Name="PercentText" Grid.Column="1" Text="0%" Foreground="White" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="300,*" Margin="22">
      <Border Background="White" CornerRadius="8" Padding="18" BoxShadow="0 4 16 #22000000">
        <StackPanel Spacing="14">
          <TextBlock Text="Сегодня" FontSize="20" FontWeight="Bold" />
          <TextBlock x:Name="TotalText" Text="0 / 2000 мл" FontSize="28" FontWeight="Bold" Foreground="#0E7490" />
          <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="18" />

          <Separator />
          <TextBlock Text="Быстро добавить" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="SmallButton" Content="+200" Click="QuickAdd_Click" />
            <Button x:Name="MediumButton" Content="+300" Click="QuickAdd_Click" />
            <Button x:Name="LargeButton" Content="+500" Click="QuickAdd_Click" />
          </StackPanel>

          <TextBlock Text="Своя порция, мл" FontWeight="SemiBold" />
          <NumericUpDown x:Name="AmountInput" Minimum="50" Maximum="2000" Increment="50" Value="250" />
          <Button Classes="primary" Content="Добавить воду" Click="AddCustom_Click" />

          <Separator />
          <TextBlock Text="Главная цель на день, мл" FontWeight="SemiBold" />
          <NumericUpDown x:Name="GoalInput" Minimum="500" Maximum="6000" Increment="100" Value="2000" />
          <Button Classes="goalAction" Content="Изменить главную цель" Click="SaveGoal_Click" />

          <Separator />
          <Button Content="Сбросить сегодня" Background="#EF4444" Foreground="White" FontWeight="Bold" Click="ResetToday_Click" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="18" Margin="18,0,0,0" BoxShadow="0 4 16 #22000000">
        <Grid RowDefinitions="Auto,310,*">
          <TextBlock Text="Визуальный прогресс" FontSize="20" FontWeight="Bold" />

          <Grid Grid.Row="1" Margin="0,12,0,18" ColumnDefinitions="*,170,*">
            <Border Grid.Column="1"
                    Width="122"
                    Height="268"
                    BorderBrush="#0E7490"
                    BorderThickness="4"
                    CornerRadius="34,34,18,18"
                    Background="#F8FAFC"
                    ClipToBounds="True"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <Grid>
                <Border x:Name="BottleFill"
                        Background="#38BDF8"
                        VerticalAlignment="Bottom"
                        Height="0" />
                <TextBlock x:Name="BottleText"
                           Text="0%"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <TextBlock Text="История за сегодня" FontSize="20" FontWeight="Bold" />
            <ListBox x:Name="HistoryList" Grid.Row="1" Margin="0,14,0,0" />
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#164E63" Padding="22,14">
      <TextBlock x:Name="StatusText" Text="Добавляй выпитую воду в течение дня." Foreground="White" FontSize="16" VerticalAlignment="Center" />
    </Border>
  </Grid>
</Window>
